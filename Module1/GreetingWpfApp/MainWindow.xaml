<Window x:Class="GreetingWpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GreetingWpfApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="200" Width="300"
        FontSize="16"
        WindowStartupLocation="CenterScreen"
        FocusManager.FocusedElement="{Binding ElementName=txtUsername}">
    <Grid>
        <StackPanel Margin="20,20,20,20" Grid.ColumnSpan="2">
            <Label Content="Enter your name:" Margin="0,0,0,5" TabIndex="2"/>
            <TextBox x:Name="txtUsername" Width="200" Margin="0,0,0,10" MaxLength="20" TabIndex="0" KeyDown="TxtUsername_KeyDown" />
            <Button Content="Greet" Width="100" Click="BtnGreet_Click" TabIndex="1"/>
        </StackPanel>
    </Grid>
</Window>
